RewriteEngine On
RewriteBase /

# 1. Ανακατεύθυνση παλιών URLs κατηγοριών
RewriteCond %{THE_REQUEST} GET\ /products\?category=([^&\ ]+) [NC]
RewriteRule ^ products/%1? [R=301,L]

# 2. Ανακατεύθυνση παλιών URLs προϊόντων
RewriteCond %{THE_REQUEST} GET\ /product-view\?product=([^&\ ]+) [NC]
RewriteRule ^ product/%1? [R=301,L]

# 3. Εσωτερική δρομολόγηση για προϊόντα (deckrush.gr/product/slug)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^product/([^/]+)$ product-view.php?product=$1 [L,QSA]

# 4. Αυτόματη αφαίρεση της επέκτασης .php (Προηγείται για να ανοίγουν οι κανονικές σελίδες)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# 5. Εσωτερική δρομολόγηση για κατηγορίες 
# (Εκτελείται ΜΟΝΟ αν η λέξη ΔΕΝ αντιστοιχεί σε κανένα πραγματικό αρχείο .php του server)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php !-f
RewriteCond %{REQUEST_URI} !\.php$ [NC]
RewriteRule ^([^/]+)$ products.php?category=$1 [L,QSA]

# 6. Σελίδα Σφάλματος 404
ErrorDocument 404 /404.php

# 7. Ταχύτητα & Gzip Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>
