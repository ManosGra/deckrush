# Ενεργοποιούμε την αναδιάρθρωση URLs
RewriteEngine On
RewriteBase /

# --- ΑΠΕΝΕΡΓΟΠΟΙΗΘΗΚΕ ΤΟΠΙΚΑ (Προστέθηκε #): Θα το ενεργοποιήσετε ΜΟΝΟ στο live site ---
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 1. Ανακατεύθυνση από το παλιό URL κατηγορίας στο νέο
RewriteCond %{THE_REQUEST} GET\ /products\?category=([^&\ ]+) [NC]
RewriteRule ^ products/%1? [R=301,L]

# 2. Ανακατεύθυνση από το παλιό URL προϊόντος στο νέο
RewriteCond %{THE_REQUEST} GET\ /product-view\?product=([^&\ ]+) [NC]
RewriteRule ^ product/%1? [R=301,L]

# 3. Εσωτερική αναδρομολόγηση για προϊόντα (deckrush.local/product/slug -> product-view.php?product=slug)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^product/([^/]+)$ product-view.php?product=$1 [L,QSA]

# 4. Εσωτερική αναδρομολόγηση για κατηγορίες (deckrush.local/onepiece -> products.php?category=onepiece)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)$ products.php?category=$1 [L,QSA]

# 5. Αφαίρεση της επέκτασης .php από τα υπόλοιπα URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(index|cart|login-register|categories|checkout|contact|edit-profile|filters|forgot|login|logout|my-account|orders|payments|product-view|products|registration|reset-password|search|special-price|top-sale|view-order)$ $1.php [NC,L,QSA]

# Σελίδα 404 αν δεν βρεθεί η σελίδα
ErrorDocument 404 /404.php
